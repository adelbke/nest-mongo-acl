{
  "name": "@biocomputingup/nest-mongo-acl",
  "version": "1.0.0",
  "description": "A NestJS module for Access Control List (ACL) management using MongoDB, Mongoose, and Typegoose.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typings": "dist/index.d.ts",
  "scripts": {
    "build": "rimraf -rf dist && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build:lib": "rimraf -rf dist && tsc -p tsconfig.build.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "author": {
    "name": "Kamel Eddine Adel Bouhraoua",
    "email": "adelbouhraoua23@gmail.com",
    "url": "https://github.com/adelbke"
  },
  "dependencies": {
    "@nestjs/common": "11",
    "@nestjs/core": "11",
    "@nestjs/platform-express": "11",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@m8a/nestjs-typegoose": "12",
    "@nestjs/cli": "11",
    "@nestjs/mongoose": "11",
    "@nestjs/schematics": "11",
    "@nestjs/testing": "11",
    "@typegoose/typegoose": "12",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "install-peers": "^1.0.4",
    "jest": "^29.5.0",
    "mongoose": "8",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "peerDependencies": {
    "@m8a/nestjs-typegoose": "^12.0.1",
    "@nestjs/mongoose": "10",
    "@typegoose/typegoose": "12",
    "class-transformer": "^0.5.1",
    "mongoose": "8"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "lib",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  },
  "bugs": {
    "url": "https://github.com/BioComputingUP/nest-mongo-acl/issues"
  },
  "homepage": "https://github.com/BioComputingUP/nest-mongo-acl#readme",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "keywords": [
    "nestjs",
    "MongoDB",
    "Mongoose",
    "Typegoose"
  ]
}
